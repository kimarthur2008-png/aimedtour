rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Публичное чтение, запись только для авторизованных
    match /hospitals/{id}  { allow read: if true; allow write: if request.auth != null; }
    match /diseases/{id}   { allow read: if true; allow write: if request.auth != null; }
    match /cases/{id}      { allow read: if true; allow write: if request.auth != null; }
    match /tourism/{id}    { allow read: if true; allow write: if request.auth != null; }
    match /settings/{id}   { allow read: if true; allow write: if request.auth != null; }

    // Заявки: создать может любой (форма без входа), читать/менять — только auth
    // BE-10: updateDoc для смены статуса (new → in-progress → done) — покрывается update
    match /consultations/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Пользователи: только свой профиль
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Результаты алгоритма: только авторизованные
    match /algorithmResults/{id} {
      allow read, write: if request.auth != null;
    }
  }
}

// ── BE-08: Firebase Storage Rules ──────────────────────────────────────────
